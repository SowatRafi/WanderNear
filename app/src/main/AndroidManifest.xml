<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Foreground-only location, used once per search to rank "near me".
         We never track location in the background. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Post anniversary + "you're back nearby" reminders (Android 13+ asks once). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Microphone for offline voice input (Vosk); requested in-context on first use. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Download / refresh a city's data pack from the free OSM + Wikipedia APIs,
         and only refresh when the phone is online. We only ever FETCH public map
         data here — no user data is ever sent off the device. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Travel Mode: a WHILE-IN-USE location foreground service, started only from
         the user's on-screen toggle and always shown by a visible notification.
         We deliberately do NOT add ACCESS_BACKGROUND_LOCATION — no silent tracking. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.WanderNear">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Travel Mode's foreground service. Not exported; location type so the
             system knows why it runs. Started only while the app is visible. -->
        <service
            android:name=".travel.TravelModeService"
            android:exported="false"
            android:foregroundServiceType="location" />
    </application>

</manifest>
